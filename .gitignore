# секреты и локальная конфигурация
.env
*.env

# Экспорт реалма Keycloak — внутри пользователи с credentials
/deployments/keycloak/import/
!.env.example

# собранные бинарники (якорь к корню — иначе матчит cmd/server, cmd/migrate, internal/server)
/bin/
/build/
*.exe
/dpmodule
/server
/migrate

# логи
*.log
/var/log/

# временное / IDE
/tmp/
.idea/
.vscode/
*.swp
.DS_Store

# клиентские seed-данные справочников — вне репозитория, грузятся per-deployment
_reference/seed/

# локальное файловое хранилище (загруженные файлы ЛК и т.п.) — вне репозитория
/_data/

# локальный dev-Keycloak (realm с тестовыми юзерами/паролями) — вне репозитория
deploy/keycloak/

# дампы БД (восстановление/бэкапы) — вне репозитория
*.dump
