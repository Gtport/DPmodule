# Скопировать в deployments/keycloak/.env и подставить свои значения.
# Настоящий .env в git не попадает (см. .gitignore) — секреты из CI/Vault.

# Первичный админ Keycloak. Создаётся ТОЛЬКО при пустом volume kc_data;
# на уже развёрнутой инсталляции смена этих значений ничего не меняет.
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=смени-меня

# Публичный URL приложения — со схемой, без завершающего слэша.
# Ровно эта строка попадёт в claim `iss` токена и обязана совпадать
# с `keycloak.issuer` в config.yaml бэкенда (там же + /realms/iqport).
KC_HOSTNAME=https://app.example.com
